{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/scaffold_hard_gate.py pre_tool",
            "timeout": 30,
            "statusMessage": "Checking scaffold hard gates"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/scaffold_hard_gate.py stop",
            "timeout": 60,
            "statusMessage": "Running scaffold stop gates"
          }
        ]
      }
    ]
  }
}
